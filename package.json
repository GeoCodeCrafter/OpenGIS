{
  "name": "opengis",
  "version": "0.1.0",
  "description": "Open-source desktop GIS application with automatic georeferencing — import any image, detect coordinate clues, and produce georeferenced output.",
  "productName": "OpenGIS",
  "author": "OpenGIS Contributors",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "homepage": "https://github.com/GeoCodeCrafter/OpenGIS",
  "repository": {
    "type": "git",
    "url": "https://github.com/GeoCodeCrafter/OpenGIS.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "electron:dev": "cross-env ELECTRON=true vite",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "electron:publish": "cross-env ELECTRON=true vite build && electron-builder --publish always",
    "electron:preview": "cross-env ELECTRON=true vite build && electron ."
  },
  "dependencies": {
    "@turf/turf": "^7.0.0",
    "clsx": "^2.1.1",
    "geotiff": "^2.1.3",
    "lucide-react": "^0.372.0",
    "ol": "^9.2.4",
    "proj4": "^2.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "tesseract.js": "^5.1.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/proj4": "^2.5.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  }
}
